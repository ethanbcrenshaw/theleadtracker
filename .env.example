# Copy this file to .env and fill in real values. Never commit .env.

# Supabase project (create at https://supabase.com/dashboard)
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Service role key — server-side only, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Same values again for the Vite client bundle
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Google Places API (Google Cloud Console) — lead generation
GOOGLE_PLACES_API_KEY=""

# Firecrawl (https://firecrawl.dev dashboard) — website enrichment + the
# WEB SEARCH discovery source (off-Google lead finding)
FIRECRAWL_API_KEY=""

# Foursquare Places API (optional) — extra discovery source with a POI base
# independent from Google's. Create a SERVICE key (not a legacy Places key)
# in the Foursquare developer console. Leave blank to disable the source.
FOURSQUARE_API_KEY=""

# Lovable AI gateway — assistant, call scripts, daily brief, summaries
LOVABLE_API_KEY=""
