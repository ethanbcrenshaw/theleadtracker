{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "lead-tracker-mcp",
      "version": "0.1.0",
      "title": "Lead Tracker CRM"
    },
    "tools": [
      {
        "name": "list_leads",
        "title": "List leads",
        "description": "List leads from the CRM, optionally filtered by status, quality, or city. Returns up to `limit` leads.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Filter by lead status",
              "type": "string",
              "enum": [
                "Not Called",
                "Called",
                "Voicemail",
                "Callback Scheduled",
                "Zoom Booked",
                "Sold",
                "Not Interested"
              ]
            },
            "quality": {
              "description": "Filter by quality tier",
              "type": "string",
              "enum": [
                "High",
                "Medium",
                "Low"
              ]
            },
            "city": {
              "description": "Filter by city (exact match)",
              "type": "string"
            },
            "limit": {
              "description": "Max leads to return (default 50)",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_lead",
        "title": "Get lead",
        "description": "Fetch a single lead by ID, including notes, history, and any call records.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "The lead ID"
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "search_leads",
        "title": "Search leads",
        "description": "Search leads by business name or city (case-insensitive substring match).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Text to match against business name or city"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_followups_due",
        "title": "List follow-ups due",
        "description": "List leads whose next follow-up date is today or earlier (most overdue first).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "update_lead_status",
        "title": "Update lead status",
        "description": "Update a lead's status and append a history entry. Sets lastContacted to now.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "Not Called",
                "Called",
                "Voicemail",
                "Callback Scheduled",
                "Zoom Booked",
                "Sold",
                "Not Interested"
              ]
            },
            "note": {
              "description": "Optional note to attach to the history entry",
              "type": "string"
            }
          },
          "required": [
            "id",
            "status"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "add_lead_note",
        "title": "Add lead note",
        "description": "Append a note to a lead's notes field (separated by a blank line).",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "note": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "id",
            "note"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "schedule_followup",
        "title": "Schedule follow-up",
        "description": "Set or clear a lead's next follow-up date (ISO 8601). Pass null to clear.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "nextFollowUp": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ISO 8601 date/time, or null to clear"
            }
          },
          "required": [
            "id",
            "nextFollowUp"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
